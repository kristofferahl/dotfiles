#!/usr/bin/env bash

function github() {
  local action="${1}"
  local remote='origin'
  local address
  local branch
  local url="https://github.com"
  if [[ ! -d .git ]]; then
    echo "Not a github repository..."
  else
    address="$(git remote -v | sed -rn "s/^${remote}(.*)\.git \(fetch\)$/\1/p" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    branch="$(git rev-parse --abbrev-ref HEAD)"
    url="${url:?}/$(echo "$address" | sed -rn 's/^git@github.com:(.*)$/\1/p')"
    if [[ "${branch:?}" != 'main' && "${branch:?}" != 'master' ]]; then
      case "${action}" in
        pr) url="${url:?}/pull/new/${branch:?}" ;;
        *) url="${url:?}/tree/${branch:?}" ;;
      esac
    fi
  fi
  echo "Opening ${url}"
  open "${url}"
}

function aws-dotenv-credenitals() {
  [[ "${AWS_REGION:-}" != '' ]] && echo "AWS_REGION=${AWS_REGION:?}"
  echo "AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID:?}"
  echo "AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY:?}"
  [[ "${AWS_SESSION_TOKEN:-}" != '' ]] && echo "AWS_SESSION_TOKEN=${AWS_SESSION_TOKEN:?}"
}

function aws-s3-permanently-delete() {
  local bucket="${1:?'A bucket name is required'}"
  local prefix="${2:?'A prefix is required'}"
  local yes="${3:-'n'}"
  local json
  local item_count=0

  json="$(aws s3api list-object-versions --bucket "${bucket:?}" --prefix "${prefix:?}" | jq '{Objects: [((.Versions // []) + (.DeleteMarkers // []))[] | {Key:.Key, VersionId : .VersionId}], Quiet: false}')"
  if [[ "${json:-}" != '' ]]; then
    item_count="$(echo "${json}" | jq '.Objects | length')"
  fi

  if [[ "${yes:-}" == '-y' ]]; then
    echo "Deleting all versions of ${item_count:?} object(s) in s3://${bucket:?}/${prefix:?}..."
    yn='yes'
  else
    echo -n "Delete all versions of ${item_count:?} object(s) in s3://${bucket:?}/${prefix:?} (yes/no)? "
    read -r yn
  fi

  if [[ ${item_count:?} != 0 && "${yn:-'no'}" == 'yes' ]]; then
    aws s3api delete-objects \
      --bucket "${bucket:?}" \
      --delete "${json:?}"
  fi
}

function zel() {
  local session_name="${1:?}"
  if zellij list-sessions -s 2>/dev/null | grep -wE "${session_name:?}"; then
    echo "Session ${session_name:?} already exists, attaching..."
    zellij attach "${session_name:?}"
  else
    echo "Creating new session ${session_name:?}..."
    zellij -n "$HOME/develop/github/dotfiles/.config/zellij/layouts/${session_name:?}.kdl" -s "${session_name:?}"
  fi
}

# secrets
function secrets() {
  # Use "gopass edit --create <path>" to set secrets
  export DATADOG_API_KEY=$(gopass show -o secrets/datadoghq.eu/api_key)
  export DATADOG_APP_KEY=$(gopass show -o secrets/datadoghq.eu/app_key)
  export TAILSCALE_OAUTH_CLIENT_ID=$(gopass show -o secrets/tailscale.com/oauth_client_id)
  export TAILSCALE_OAUTH_CLIENT_SECRET=$(gopass show -o secrets/tailscale.com/oauth_client_secret)
  export OKTA_API_TOKEN=$(gopass show -o secrets/okta.com/api_token)
  export OPENAI_API_KEY=$(gopass show -o secrets/openai.com/api_key)
  export JIRA_API_TOKEN=$(gopass show -o secrets/atlassian.com/jira/api_token)
  export LETTA_API_KEY=$(gopass show -o secrets/letta.com/api_key)
}

function ssh-restart() {
  killall ssh-agent
  eval "$(ssh-agent)"
}
